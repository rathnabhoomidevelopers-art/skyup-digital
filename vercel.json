{
  "trailingSlash": false,
  "outputDirectory": "build/client",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "skyupdigitalsolutions.com" }],
      "destination": "https://www.skyupdigitalsolutions.com/:path*",
      "permanent": true
    },
    {
      "source": "/careers",
      "destination": "/careers-digital-marketing-job",
      "permanent": true
    },
    {
      "source": "/aboutus",
      "destination": "/aboutus-digital-marketing-company-in-bangalore",
      "permanent": true
    },
    {
      "source": "/blogs",
      "destination": "/blogs-difference-between-digital-marketing-and-traditional-marketing",
      "permanent": true
    },
    {
      "source": "/contactus",
      "destination": "/contact-us",
      "permanent": true
    },
    {
      "source": "/digital-marketing-services-in-bangalore",
      "destination": "/service",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://skyup-backend-3k9s.onrender.com/api/$1"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/blogger/(.*)",
      "destination": "/blogger/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}